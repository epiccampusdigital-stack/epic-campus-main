# Kitchen alerts — admin WhatsApp number in format +94XXXXXXXXX
ADMIN_WHATSAPP_NUMBER=+94XXXXXXXXX

# Twilio WhatsApp sandbox join keyword (Console → Messaging → Try it out → Send a WhatsApp message)
# Only needed while the Twilio WhatsApp number is in sandbox mode — remove once upgraded to a live number.
NEXT_PUBLIC_TWILIO_SANDBOX_KEYWORD=your-sandbox-keyword
