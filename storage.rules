rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /students/{studentId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == studentId;
    }
    match /staff/{staffId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == staffId ||
        request.auth.token.role in ['admin','owner']
      );
    }
    match /visaDocs/{studentId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == studentId ||
        request.auth.token.role in ['admin','owner','reception','accountant']
      );
      allow write: if request.auth != null && request.auth.uid == studentId;
      allow delete: if request.auth != null && (
        request.auth.uid == studentId ||
        request.auth.token.role in ['admin','owner','reception']
      );
    }
    match /epicWall/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null && (
        request.auth.token.role in ['admin','owner'] ||
        resource.name.matches('.*/' + request.auth.uid + '/.*')
      );
    }
    match /epicStories/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null && (
        request.auth.token.role in ['admin','owner'] ||
        resource.name.matches('.*/' + request.auth.uid + '/.*')
      );
    }
    match /examQuestions/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin','owner','teacher','examCoordinator'];
    }
    match /kitchen/{allPaths=**} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['admin','owner','kitchen'];
    }
  }
}
