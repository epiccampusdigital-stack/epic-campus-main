rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /students/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /staff/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /visaDocs/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /materials/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.role in ['admin','owner','teacher','reception','examCoordinator']
      );
    }

    match /epicWall/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /epicStories/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /examQuestions/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.role in ['admin','owner','teacher','examCoordinator']
      );
    }

    match /kitchen/{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.role in ['admin','owner','kitchen']
      );
    }

    match /ssw-migration/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.role in ['admin','owner']
      );
    }

    match /payment-receipts/{userId}/{fileName} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId ||
        request.auth.token.role in ['admin', 'owner', 'reception', 'accountant']);
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
