rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /students/{studentId}/photo.{ext} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == studentId;
    }
    match /visaDocs/{studentId}/{fileName} {
      allow read: if request.auth != null && (
        request.auth.uid == studentId ||
        request.auth.token.role in ['admin', 'owner', 'reception', 'accountant']
      );
      allow write: if request.auth != null &&
        request.auth.uid == studentId;
      allow delete: if request.auth != null && (
        request.auth.uid == studentId ||
        request.auth.token.role in ['admin', 'owner', 'reception']
      );
    }
    match /epicWall/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == userId;
      allow delete: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.role in ['admin', 'owner']
      );
    }
    match /epicStories/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == userId;
      allow delete: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.role in ['admin', 'owner']
      );
    }
    match /kitchen/{allPaths=**} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'kitchen'];
    }
  }
}
