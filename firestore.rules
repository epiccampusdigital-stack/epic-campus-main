rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — read own, write own on create
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // Students — read/write own record, admin can read all
    match /students/{studentId} {
      allow read: if request.auth != null && (
        request.auth.uid == studentId ||
        request.auth.token.role in ['admin', 'owner', 'reception', 'accountant', 'teacher']
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == studentId ||
        request.auth.token.role in ['admin', 'owner', 'reception']
      );
    }

    // Payments — staff only
    match /payments/{paymentId} {
      allow read: if request.auth != null && (
        request.auth.token.role in ['admin', 'owner', 'accountant', 'reception'] ||
        resource.data.studentId == request.auth.uid
      );
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'accountant', 'reception'];
    }

    // Audit log — admin/owner read only, server writes only
    match /auditLog/{logId} {
      allow read: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner'];
      allow write: if false;
    }

    // Exams — staff read/write, students read only
    match /exams/{examId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin', 'teacher', 'examCoordinator'];
    }

    // Exam results — own results or staff
    match /examResults/{resultId} {
      allow read: if request.auth != null && (
        resource.data.studentId == request.auth.uid ||
        request.auth.token.role in ['admin', 'teacher', 'examCoordinator']
      );
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin', 'teacher', 'examCoordinator'];
    }

    // Leads — staff only
    match /leads/{leadId} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'reception'];
    }

    match /partnerCompanies/{docId} {
      allow read, write: if request.auth != null;
    }

    match /candidateShortlists/{docId} {
      allow read, write: if request.auth != null;
    }

    match /notifications/{docId} {
      allow read, write: if request.auth != null;
    }

    match /parentAccounts/{accountId} {
      allow read: if request.auth != null && (
        request.auth.uid == accountId ||
        request.auth.token.role in ['admin', 'owner', 'reception']
      );
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'reception'];
    }

    match /attendance/{recordId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'reception', 'teacher'];
    }

    match /broadcastMessages/{docId} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'reception'];
    }

    match /broadcastLogs/{docId} {
      allow read: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'reception'];
      allow write: if false;
    }

    // Public inquiries from contact form
    match /inquiries/{inquiryId} {
      allow create: if request.resource.data.keys().hasAll(['fullName', 'email', 'phone', 'program'])
        && request.resource.data.fullName is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.program is string;
      allow read, update: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'reception'];
    }

    // AI chat history — student reads/writes own history, staff can read
    match /aiChatHistory/{studentId}/messages/{messageId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == studentId ||
        request.auth.token.role in ['admin', 'owner', 'teacher']
      );
    }

    // Study sessions — student reads/writes own sessions, staff can read
    match /studySessions/{sessionId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        request.auth.token.role in ['admin', 'owner', 'teacher']
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.studentId;
    }

    // Enrollment applications — public create (unauthenticated via API), staff read/update
    match /enrollmentApplications/{enrollmentId} {
      allow read: if request.auth != null && (
        request.auth.token.role in ['admin', 'owner', 'reception'] ||
        request.auth.uid == resource.data.studentId
      );
      allow create: if true;
      allow update: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'reception'];
    }

    // Public chatbot logs — admin/owner read only, only server writes
    match /publicChatLogs/{docId} {
      allow read: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner'];
      allow write: if false;
    }

    // Study materials — any authenticated user can read, staff can write
    match /studyMaterials/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'teacher'];
    }

    // Kitchen module
    match /inventory/{doc} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['kitchen', 'admin', 'owner'];
    }

    match /inventory/{doc}/history/{h} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['kitchen', 'admin', 'owner'];
    }

    match /mealLogs/{doc} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['kitchen', 'admin', 'owner'];
      allow read: if request.auth != null &&
        request.auth.token.role == 'accountant';
    }

    match /wasteLog/{doc} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['kitchen', 'admin', 'owner'];
    }

    match /kitchenOrders/{doc} {
      allow create, read, update: if request.auth != null &&
        request.auth.token.role == 'kitchen';
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner'];
      allow read: if request.auth != null &&
        request.auth.token.role == 'accountant';
    }

    match /kitchenBudget/{doc} {
      allow read: if request.auth != null &&
        request.auth.token.role in ['kitchen', 'admin', 'owner', 'accountant'];
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner'];
    }

    match /expenses/{doc} {
      allow read: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'accountant'];
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner'];
    }

    match /agentCommissions/{doc} {
      allow read: if request.auth != null &&
        request.auth.token.role == 'agent' &&
        resource.data.agentId == request.auth.uid;
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner'];
      allow read: if request.auth != null &&
        request.auth.token.role == 'accountant';
    }

    match /staffReferrals/{doc} {
      allow read: if request.auth != null && (
        request.auth.token.role in ['admin', 'owner', 'accountant'] ||
        resource.data.staffId == request.auth.uid
      );
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'accountant'];
    }

    match /payroll/{doc} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'accountant'];
    }

    match /parentPortalCodes/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'reception'];
    }

    match /riskCache/{doc} {
      allow read: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'teacher'];
      allow write: if request.auth != null &&
        request.auth.token.role in ['admin', 'owner', 'teacher'];
    }
  }
}
